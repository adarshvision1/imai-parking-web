@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg: #f8fafc;
  --bg-gradient: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  --surface: #ffffff;
  --surface-solid: #ffffff;
  --surface-2: #f1f5f9;
  --surface-hover: #e2e8f0;
  --glass: rgba(255, 255, 255, 0.8);
  --border: rgba(0, 0, 0, 0.07);
  --border-subtle: rgba(0, 0, 0, 0.04);
  --border-accent: rgba(76, 175, 80, 0.25);
  --text: #0f172a;
  --text-2: #475569;
  --text-3: #94a3b8;
  --green: rgb(76, 175, 80);
  --green-dim: rgba(76, 175, 80, 0.08);
  --red: #ef4444;
  --red-dim: rgba(239, 68, 68, 0.08);
  --amber: #f59e0b;
  --amber-dim: rgba(245, 158, 11, 0.08);
  --blue: #2563eb;
  --blue-dim: rgba(37, 99, 235, 0.08);
  --purple: #7c3aed;
  --purple-dim: rgba(124, 58, 237, 0.08);
  --accent-gradient: linear-gradient(135deg, rgb(76, 175, 80) 0%, #2e7d32 100%);
  --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --mono: 'JetBrains Mono', 'Courier New', monospace;
  --radius: 12px;
  --radius-sm: 8px;
  --radius-lg: 16px;
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.04), 0 4px 6px -4px rgba(0, 0, 0, 0.04);
  --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

html { scroll-behavior: smooth; }

body {
  background: var(--bg);
  background-image: var(--bg-gradient);
  background-attachment: fixed;
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  min-height: 100vh;
}

/* ─── Selection ─── */
::selection { background: rgba(76, 175, 80, 0.15); color: var(--green); }

/* ─── Layout ─── */
#app { display: flex; flex-direction: column; min-height: 100vh; }

/* ─── Top Bar ─── */
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  height: 56px;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.02);
}
.topbar-left { display: flex; align-items: center; gap: 18px; }
.topbar-brand {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: -0.4px;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.zone-selector {
  background: var(--surface-2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 6px 12px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-family: var(--font);
  cursor: pointer;
  transition: border-color var(--transition), background-color var(--transition);
  outline: none;
  appearance: auto;
}
.zone-selector:hover { border-color: var(--green); background-color: var(--surface-hover); }
.zone-selector:focus { border-color: var(--green); box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.15); }
.zone-selector option { background: var(--surface-solid); color: var(--text); }

.topbar-right { display: flex; align-items: center; gap: 12px; font-size: 13px; color: var(--text-2); }
.live-dot {
  width: 8px; height: 8px;
  background: var(--green);
  border-radius: 50%;
  box-shadow: 0 0 8px rgba(76, 175, 80, 0.4);
  animation: pulse-green 2s ease-in-out infinite;
}
.live-dot.loading {
  background: var(--amber);
  box-shadow: 0 0 8px rgba(251, 191, 36, 0.4);
  animation: pulse-amber 1s ease-in-out infinite;
}
@keyframes pulse-green {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(76, 175, 80, 0.4); }
  50% { opacity: 0.5; box-shadow: 0 0 16px rgba(76, 175, 80, 0.2); }
}
@keyframes pulse-amber {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(251, 191, 36, 0.4); }
  50% { opacity: 0.4; box-shadow: 0 0 4px rgba(251, 191, 36, 0.1); }
}

/* ─── Loading screen ─── */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  height: 60vh;
  color: var(--text-2);
  font-size: 14px;
}
.spinner {
  width: 32px; height: 32px;
  border: 3px solid var(--surface-2);
  border-top-color: var(--green);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ─── Nav Tabs ─── */
.nav-tabs {
  display: flex;
  gap: 2px;
  padding: 0 28px;
  background: #ffffff;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
}
.nav-tabs::-webkit-scrollbar { display: none; }
.nav-tab {
  padding: 14px 16px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-2);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: color var(--transition), border-color var(--transition), background var(--transition);
  white-space: nowrap;
  user-select: none;
}
.nav-tab:hover { color: var(--text); background: var(--surface-2); }
.nav-tab.active {
  color: var(--green);
  font-weight: 600;
  border-bottom-color: var(--green);
  background: rgba(76, 175, 80, 0.03);
}

/* ─── Main content ─── */
.main {
  padding: 28px;
  max-width: 1440px;
  width: 100%;
  margin: 0 auto;
  animation: fadeUp 0.3s ease-out;
}
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ─── Stat row ─── */
.stat-row {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
  gap: 16px;
  margin-bottom: 28px;
}
.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px;
  transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--accent-gradient);
  opacity: 0;
  transition: opacity var(--transition);
}
.stat-card:hover {
  border-color: rgba(76, 175, 80, 0.3);
  box-shadow: var(--shadow);
  transform: translateY(-1px);
}
.stat-card:hover::before { opacity: 1; }
.stat-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 8px;
}
.stat-value {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.8px;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
  color: var(--text);
}
.stat-sub { font-size: 12px; color: var(--text-2); margin-top: 6px; }

.green { color: var(--green); }
.red { color: var(--red); }
.amber { color: var(--amber); }
.blue { color: var(--blue); }
.purple { color: var(--purple); }

/* ─── Section card ─── */
.section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  margin-bottom: 18px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: border-color var(--transition), box-shadow var(--transition);
}
.section:hover { border-color: rgba(76, 175, 80, 0.15); box-shadow: var(--shadow); }
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border-subtle);
  background: rgba(0, 0, 0, 0.01);
}
.section-title { font-size: 14px; font-weight: 600; color: var(--text); letter-spacing: -0.2px; }
.section-meta { font-size: 12px; color: var(--text-2); }

/* ─── Data table ─── */
.data-table { width: 100%; border-collapse: collapse; }
.data-table th {
  padding: 11px 20px;
  text-align: left;
  font-size: 11px;
  font-weight: 600;
  color: var(--text-2);
  text-transform: uppercase;
  letter-spacing: 0.6px;
  border-bottom: 1px solid var(--border);
  background: #f8fafc;
  position: sticky;
  top: 0;
}
.data-table td {
  padding: 12px 20px;
  font-size: 13px;
  border-bottom: 1px solid var(--border-subtle);
  vertical-align: middle;
  transition: background var(--transition);
  color: var(--text-2);
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tbody tr {
  transition: background var(--transition);
}
.data-table tbody tr:hover td { background: var(--surface-2); }

/* ─── Badge ─── */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  padding: 3px 10px;
  border-radius: 6px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.2px;
  white-space: nowrap;
}
.badge-green { background: var(--green-dim); color: var(--green); }
.badge-red   { background: var(--red-dim); color: var(--red); }
.badge-amber { background: var(--amber-dim); color: var(--amber); }
.badge-blue  { background: var(--blue-dim); color: var(--blue); }
.badge-purple{ background: var(--purple-dim); color: var(--purple); }
.badge-gray  { background: rgba(0, 0, 0, 0.04); color: var(--text-2); }

/* ─── Spot grid ─── */
.spot-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(76px, 1fr));
  gap: 10px;
  padding: 20px;
}
.spot {
  border-radius: var(--radius-sm);
  padding: 12px 6px;
  text-align: center;
  cursor: pointer;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  border: 1px solid transparent;
  position: relative;
}
.spot:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
.spot.spot-selected { box-shadow: 0 0 0 2px var(--green), var(--shadow); }
.spot-id { font-size: 12px; font-weight: 700; display: block; font-family: var(--mono); letter-spacing: 0.5px; }
.spot-type { font-size: 10px; color: var(--text-2); display: block; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.3px; }

.spot-vacant { background: var(--green-dim); border-color: rgba(76, 175, 80, 0.15); }
.spot-vacant .spot-id { color: var(--green); }

.spot-occupied { background: var(--red-dim); border-color: rgba(239, 68, 68, 0.15); }
.spot-occupied .spot-id { color: var(--red); }

.spot-reserved { background: var(--amber-dim); border-color: rgba(245, 158, 11, 0.15); }
.spot-reserved .spot-id { color: var(--amber); }

/* ─── Detail panel ─── */
.detail-panel { padding: 20px; display: flex; flex-direction: column; gap: 14px; }
.detail-row { display: flex; justify-content: space-between; align-items: center; }
.detail-key { font-size: 12px; color: var(--text-2); font-weight: 500; }
.detail-val { font-size: 13px; font-weight: 600; color: var(--text); }
.plate {
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 1.2px;
  color: var(--text);
  background: var(--surface-2);
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}

/* ─── Grid layouts ─── */
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.three-col { display: grid; grid-template-columns: 5fr 3fr; gap: 18px; }
@media (max-width: 960px) {
  .two-col, .three-col { grid-template-columns: 1fr; }
}

/* ─── Log entries ─── */
.log-entry {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: 14px 20px;
  border-bottom: 1px solid var(--border-subtle);
  transition: background var(--transition);
}
.log-entry:last-child { border-bottom: none; }
.log-entry:hover { background: var(--surface-2); }
.log-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6px;
  box-shadow: 0 0 6px currentColor;
}
.log-body { flex: 1; min-width: 0; }
.log-main { font-size: 13px; font-weight: 500; color: var(--text); }
.log-sub { font-size: 12px; color: var(--text-2); margin-top: 3px; }
.log-right { text-align: right; flex-shrink: 0; }
.log-time { font-size: 11px; color: var(--text-3); font-variant-numeric: tabular-nums; font-family: var(--mono); }
.log-amount { font-size: 14px; font-weight: 700; color: var(--text); }

/* ─── Pricing ─── */
.pricing-block { padding: 20px; }
.pricing-tier {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  background: var(--surface-2);
  margin-bottom: 8px;
  border: 1px solid var(--border-subtle);
  transition: border-color var(--transition);
}
.pricing-tier:last-child { margin-bottom: 0; }
.pricing-tier:hover { border-color: rgba(76, 175, 80, 0.2); }
.pricing-label { font-size: 13px; color: var(--text-2); }
.pricing-val { font-size: 15px; font-weight: 700; color: var(--text); font-family: var(--mono); }

/* ─── Occupancy ring ─── */
.ring-container { display: flex; align-items: center; justify-content: center; padding: 24px; }
.ring-svg { transform: rotate(-90deg); }
.ring-bg { fill: none; stroke: var(--surface-2); }
.ring-fg { fill: none; stroke: var(--green); stroke-linecap: round; transition: stroke-dashoffset 0.8s ease-out; }
.ring-center {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
}
.ring-pct { font-size: 28px; font-weight: 700; color: var(--text); }
.ring-label { font-size: 11px; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.5px; }

/* ─── Revenue highlight card ─── */
.revenue-card {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.04) 0%, rgba(37, 99, 235, 0.02) 100%);
  border: 1px solid rgba(76, 175, 80, 0.12);
  border-radius: var(--radius);
  padding: 24px;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.revenue-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--green), var(--blue));
}
.revenue-card .stat-value { font-size: 32px; color: var(--green); }

/* ─── Fee highlight ─── */
.fee-amount {
  font-family: var(--mono);
  font-size: 14px;
  font-weight: 700;
  color: var(--amber);
  background: var(--amber-dim);
  padding: 3px 10px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  border: 1px solid rgba(245, 158, 11, 0.1);
}

/* ─── Image thumbnail ─── */
.img-thumb {
  width: 40px; height: 40px;
  border-radius: var(--radius-sm);
  object-fit: cover;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: transform var(--transition), box-shadow var(--transition);
}
.img-thumb:hover { transform: scale(1.1); box-shadow: var(--shadow); }

/* ─── Scrollable ─── */
.scroll-y { max-height: 480px; overflow-y: auto; }
.scroll-y::-webkit-scrollbar { width: 5px; }
.scroll-y::-webkit-scrollbar-track { background: transparent; }
.scroll-y::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 4px; }
.scroll-y::-webkit-scrollbar-thumb:hover { background: rgba(0,0,0,0.2); }

/* ─── Empty state ─── */
.empty {
  padding: 40px;
  text-align: center;
  color: var(--text-2);
  font-size: 13px;
}

/* ─── Utilities ─── */
.mono { font-family: var(--mono); }
.flex { display: flex; align-items: center; gap: 8px; }
.ml-auto { margin-left: auto; }

/* ─── Filter bar ─── */
.filter-bar {
  display: flex;
  gap: 12px;
  margin-bottom: 18px;
  align-items: center;
  flex-wrap: wrap;
}
.filter-bar .count {
  font-size: 12px;
  color: var(--text-2);
  font-variant-numeric: tabular-nums;
}

/* ─── Responsive ─── */
@media (max-width: 768px) {
  .topbar { padding: 0 16px; height: 50px; }
  .nav-tabs { padding: 0 16px; }
  .main { padding: 16px; }
  .stat-row { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .stat-card { padding: 16px; }
  .stat-value { font-size: 22px; }
  .data-table th,
  .data-table td { padding: 10px 14px; font-size: 12px; }
}

@media (max-width: 480px) {
  .stat-row { grid-template-columns: 1fr; }
  .topbar-brand { font-size: 14px; }
}

/* ─── Login screen ─── */
.login-screen {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 24px;
  background: var(--bg);
  background-image: var(--bg-gradient);
}
.login-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 48px 40px;
  max-width: 400px;
  width: 100%;
  text-align: center;
  box-shadow: var(--shadow-lg);
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.4s ease-out;
}
.login-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--accent-gradient);
}
.login-brand {
  font-size: 28px;
  font-weight: 700;
  letter-spacing: -0.8px;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 6px;
}
.login-subtitle {
  font-size: 14px;
  color: var(--text-2);
  margin-bottom: 28px;
  letter-spacing: 0.5px;
}
.login-btn {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 12px 28px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--surface-2);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition), transform var(--transition), box-shadow var(--transition);
}
.login-btn:hover {
  background: var(--surface-hover);
  border-color: var(--green);
  transform: translateY(-1px);
  box-shadow: var(--shadow);
}
.login-btn:active { transform: translateY(0); }
.login-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* ─── Sign out button ─── */
.signout-btn {
  background: var(--surface-2);
  border: 1px solid var(--border);
  color: var(--text-2);
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  cursor: pointer;
  transition: background var(--transition), color var(--transition), border-color var(--transition);
  font-family: var(--font);
}
.signout-btn:hover {
  background: var(--red-dim);
  color: var(--red);
  border-color: rgba(239, 68, 68, 0.2);
}

.hidden { display: none !important; }
